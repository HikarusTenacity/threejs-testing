{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "ignoreDeprecations": "6.0",
    "module": "None",
    "moduleResolution": "Classic",
    "removeComments": false
  },
  "include": ["js/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["js/lib/**", "node_modules", "dist"]
}
