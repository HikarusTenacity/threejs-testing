    "js/game/animations/player-animator.ts",
    "js/game/animations/dice-animator.ts",
    "js/game/ui/settings/settings-manager.ts",
    "js/game/ui/settings/settings-menu.ts",
    "js/game/ui/credits/credits-screen.ts",
    "js/game/game-manager.ts",
    "js/game/ui/player-corner-panel.ts",
    "js/game/ui/name-entry-overlay.ts",
    "js/game/ui/game-info-display.ts",
    "js/game/ui/game-ui.ts",
    "js/game/ui/menu/title-screen.ts",
    "js/game/main.ts"
  ]
