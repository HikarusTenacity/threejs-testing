{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "None",
    "moduleResolution": "Classic",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "outFile": "public/game.bundle.js",
    "removeComments": false,
    "noEmit": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
