    "js/game/board/board-layout.ts",
    "js/game/board/board-queries.ts",
    "js/game/models/dice.ts",
    "js/game/models/guy.ts",
    "js/game/models/cloud.ts",
    "js/game/models/mountain.ts",
    "js/game/models/tree.ts",
    "js/game/actors/pieces/normalize.ts",
    "js/game/actors/pieces/place.ts",
    "js/game/actors/pieces/create.ts",
    "js/game/actors/players/player-manager.ts",
    "js/game/actors/players/currency.ts",
    "js/game/actors/players/buffs.ts",
    "js/game/actors/players/getters.ts",
    "js/game/actors/actor-manager.ts",
    "js/debug/grid.ts",
    "js/debug/grid-visual.ts",
    "js/debug/fps-sampler.ts",
    "js/debug/debug-stats-formatter.ts",
    "js/debug/fps-counter.ts",
